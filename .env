NODE_ENV=development

# Backend
PORT=5000
JWT_SECRET=changeme-super-secret

# Database
MYSQL_ROOT_PASSWORD=changeme-root
MYSQL_DATABASE=calendario_db
MYSQL_USER=cal_user
MYSQL_PASSWORD=changeme-password

# Frontend
# Se non impostata, il frontend userà automaticamente
# http(s)://<hostname>:5000 (utile su AWS/EC2).
# In locale, se vuoi forzare:
# VITE_API_BASE_URL=http://localhost:5000
#
# NOTA: `http://backend:5000` funziona solo all'interno della rete Docker,
# ma non dal browser dell'utente.
# VITE_API_BASE_URL=http://backend:5000
VITE_API_BASE_URL=

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
SMTP_FROM="Calendario Aziendale <no-reply@example.com>"

# Timezone
APP_TIMEZONE=Europe/Rome

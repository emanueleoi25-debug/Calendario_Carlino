NODE_ENV=development

# Backend
PORT=5000
JWT_SECRET=changeme-super-secret

# Database
MYSQL_ROOT_PASSWORD=changeme-root
MYSQL_DATABASE=calendario_db
MYSQL_USER=cal_user
MYSQL_PASSWORD=changeme-password

# Frontend
# Per l'esecuzione in Docker i container comunicano sul nome di servizio:
# VITE_API_BASE_URL=http://backend:5000
# Per sviluppo locale puoi usare invece:
# VITE_API_BASE_URL=http://localhost:5000
VITE_API_BASE_URL=http://backend:5000

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
SMTP_FROM="Calendario Aziendale <no-reply@example.com>"

# Timezone
APP_TIMEZONE=Europe/Rome
